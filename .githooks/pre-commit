#!/bin/bash
# pre-commit hook: scan for secrets, security issues, and style violations
# Standardized March 2026 for the Antigravity Ecosystem
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

echo "[pre-commit] Running ecosystem-standard checks..."

# Function to check for secrets in staged files
check_secrets() {
    local secret_found=0
    local staged_files
    staged_files=$(git diff --cached --name-only --diff-filter=ACM)

    if [[ -z "$staged_files" ]]; then
        return 0
    fi

    echo "[pre-commit] Scanning staged files for secrets..."
    local patterns=(
        "password\s*=\s*['\"][^'\"]{8,}['\"]"
        "passwd\s*=\s*['\"][^'\"]{8,}['\"]"
        "pwd\s*=\s*['\"][^'\"]{8,}['\"]"
        "\bsecret\s*=\s*['\"][^'\"]{16,}['\"]"
        "SECRET\s*=\s*['\"][^'\"]{16,}['\"]"
        "\bapi[_-]?key\s*=\s*['\"][^'\"]{20,}['\"]"
        "apikey\s*=\s*['\"][^'\"]{20,}['\"]"
        "\btoken\s*=\s*['\"][^'\"]{20,}['\"]"
        "TOKEN\s*=\s*['\"][^'\"]{20,}['\"]"
        "PRIVATE[_-]?KEY\s*=\s*['\"][a-zA-Z0-9+/=]{20,}['\"]"
    )

    for file in $staged_files; do
        if [[ -f "$file" ]]; then
            for pattern in "${patterns[@]}"; do
                if grep -q -E "$pattern" "$file" 2>/dev/null; then
                    echo "[pre-commit] ❌ POTENTIAL SECRET FOUND in $file"
                    grep -n -E "$pattern" "$file" | head -3
                    secret_found=1
                fi
            done
        fi
    done

    if [[ $secret_found -eq 1 ]]; then
        echo "[pre-commit] 🚨 SECURITY VIOLATION: Potential secrets detected!"
        return 1
    fi
    return 0
}

# Function to run Python linting (Ruff)
run_python_lint() {
    local staged_py_files
    staged_py_files=$(git diff --cached --name-only --diff-filter=ACM | grep "\.py$" || true)

    if [[ -n "$staged_py_files" ]]; then
        if command -v ruff >/dev/null 2>&1; then
            echo "[pre-commit] Running Ruff check & format..."
            ruff check $staged_py_files --fix
            ruff format $staged_py_files
        else
            echo "[pre-commit] ⚠️  Ruff not found, skipping Python linting"
        fi
    fi
}

# Function to run Swift linting and formatting
run_swift_lint() {
    local staged_swift_files
    staged_swift_files=$(git diff --cached --name-only --diff-filter=ACM | grep "\.swift$" || true)

    if [[ -n "$staged_swift_files" ]]; then
        if command -v swiftformat >/dev/null 2>&1; then
            echo "[pre-commit] Running SwiftFormat..."
            swiftformat $staged_swift_files --quiet
        else
            echo "[pre-commit] ⚠️  SwiftFormat not found, skipping"
        fi

        if command -v swiftlint >/dev/null 2>&1; then
            echo "[pre-commit] Running SwiftLint..."
            swiftlint lint --path $staged_swift_files --quiet
        else
            echo "[pre-commit] ⚠️  SwiftLint not found, skipping"
        fi
    fi
}

# Main execution
check_secrets || exit 1
run_python_lint
run_swift_lint

echo "[pre-commit] ✅ All ecosystem checks passed"
exit 0
